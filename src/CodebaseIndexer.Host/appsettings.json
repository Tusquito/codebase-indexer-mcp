{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Qdrant": {
    "Url": "http://localhost:6334",
    "TimeoutSeconds": 30,
    "Collection": "codebase",
    "PayloadIndexes": true,
    "VectorsOnDisk": false,
    "SparseOnDisk": false,
    "Quantization": true,
    "HnswEf": 64,
    "HnswM": 16,
    "HnswEfConstruct": 128,
    "QuantOversampling": 2.0,
    "MemmapThresholdKb": 20000
  },
  "Embedding": {
    "HybridSearch": true,
    "DenseModel": "jinaai/jina-embeddings-v2-base-code",
    "SparseModel": "Qdrant/bm25",
    "DenseVectorSize": 768,
    "RerankEnabled": false,
    "ColbertEmbedModel": "colbert-ir/colbertv2.0",
    "RerankPrefetch": 100,
    "RerankMaxQueryTokens": 0,
    "RerankAdaptiveEnabled": true,
    "RerankAdaptiveGap": 0.02,
    "MaxDenseTokens": 0,
    "MaxSparseTokens": 0,
    "CachePath": "/root/.cache/fastembed",
    "SparseThreads": 2,
    "PrefetchMultiplier": 5,
    "RrfK": 60
  },
  "Colbert": {
    "EmbedModel": "colbert-ir/colbertv2.0",
    "EmbedBackend": "",
    "Url": "http://localhost:8082",
    "TimeoutSeconds": 300,
    "EmbedBatchSize": 16,
    "UseCuda": false,
    "DeviceIds": "",
    "GpuMemLimitBytes": 2147483648,
    "MaxQueryTokens": 0
  },
  "Reindex": {
    "Enabled": true,
    "Cron": "0 0 3 * * ?",
    "Interval": "",
    "GitPull": true,
    "WorkspacePath": "",
    "IndexTimeoutSeconds": 1800,
    "GitTimeoutSeconds": 120
  },
  "Tei": {
    "Url": "http://localhost:8080",
    "EmbedBatchSize": 32,
    "TimeoutSeconds": 120,
    "QueryInstruction": "",
    "NormalizeOutput": false
  },
  "Workspace": {
    "Path": "/workspace",
    "ExcludedDirs": "node_modules,.git,__pycache__,.venv,venv,dist,build,target,bin,obj,.gradle,.mypy_cache,.pytest_cache,.ruff_cache,.github,.idea,.vscode,migrations",
    "HashWorkerDop": 1,
    "ReadaheadBuffer": 100
  },
  "Chunking": {
    "MaxLines": 150,
    "OverlapLines": 20
  },
  "Indexing": {
    "SequentialEmbed": false,
    "MemoryPressureWarnPct": 70,
    "MemoryPressureHaltPct": 85,
    "ReleaseModelsAfterIndex": true,
    "FlushEvery": 1500,
    "UpsertBatch": 500,
    "BatchSize": 32,
    "PreloadModels": true,
    "ModelIdleTimeoutSeconds": 300
  },
  "Discovery": {
    "RecommendEnabled": true,
    "RecommendMaxExamples": 10,
    "OutlierMaxContextSamples": 200,
    "OutlierMaxSimilarity": 0.55,
    "ServiceUrlKeywords": "rest,api,profile,service,internal,public,gateway,graphql,webhook,auth,users,accounts",
    "ServiceDiscoveryExtraQueries": ""
  },
  "Graph": {
    "Enabled": false,
    "Neo4jUri": "bolt://localhost:7687",
    "Neo4jUser": "neo4j",
    "Neo4jPassword": "",
    "Neo4jDatabase": "neo4j",
    "WriterBatch": 500,
    "MaxHops": 2,
    "MaxNodes": 200
  }
}
