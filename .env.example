# Copy this file to .env and fill in the REQUIRED section for your machine.
# Docker Compose fails fast if any required variable is missing.
# Optional settings below override application defaults in config.py when set in .env.
# Docker Compose passes all Settings fields into mcp_server — see docs/DEPLOYMENT.md
# ("Docker Compose env passthrough"). Restart mcp_server after env-only changes.

# ===========================================================================
# REQUIRED — set these before `docker compose up`
# ===========================================================================

# Parent directory of all repos to index (mounted read-only as /workspace).
# Each direct subdirectory becomes a separate collection.
WORKSPACE_ROOT=C:\Users\me\repos

# Container resource caps (must fit your Docker VM; leave 2–3 GiB for kernel/WSL).
# Example values below target 16 CPU / 16 GB — see TUNING PRESETS to swap.
MCP_MEM_LIMIT=9g
QDRANT_MEM_LIMIT=5g
MCP_CPUS=14
QDRANT_CPUS=4
OMP_NUM_THREADS=12

# Compose-only accelerator mode (ADR 0022). Default is GPU; set ACCELERATOR=cpu only for
# CI, air-gapped CPU hosts, or explicit CPU-only deployments.
ACCELERATOR=gpu

# Embedding models (changing these requires a full re-index).
# Default: Jina v2 base code @ 768 dims — production default (ADR 0021).
DENSE_EMBED_MODEL=jinaai/jina-embeddings-v2-base-code
SPARSE_EMBED_MODEL=Qdrant/bm25
DENSE_EMBED_VECTOR_SIZE=768
# Bundled TEI (recommended). GPU override is merged by default when ACCELERATOR=gpu.
COMPOSE_PROFILES=bundled-tei
TEI_URL=http://tei:80
# ONNX threads for the sparse encoder (tune to SPARSE_EMBED_MODEL).
SPARSE_THREADS=2
#
# --- TEI dense (required; sparse BM25 stays in-process CPU in MCP) ---
# Compose-only (not Python Settings): TEI_GPU_COUNT, TEI_PORT, TEI_MEM_LIMIT, TEI_CPUS, TEI_IMAGE
# Canonical compose file list (GPU default):
#   docker compose $(python scripts/compose_files.py) --profile bundled-tei up -d --build
# External TEI on the host instead:
#   COMPOSE_PROFILES=
#   TEI_URL=http://host.docker.internal:8080
# TEI_GPU_COUNT=1
# TEI_EMBED_BATCH_SIZE=32
# TEI_TIMEOUT=120
# TEI_PORT=8080
# TEI_MEM_LIMIT=4g
# TEI_CPUS=4
# HF_TOKEN=   # gated Hub models only
#
# --- Explicit CPU-only (ACCELERATOR=cpu) — not the production default ---
# ACCELERATOR=cpu
# TEI_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-1.9
# Optional smaller model on CPU TEI:
# DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# DENSE_EMBED_VECTOR_SIZE=768
# Defaults to AVX2 (safe on virtualized/cloud CPUs that mis-report AVX-512
# support in CPUID, e.g. some GitHub Actions runners). Override on a known-good
# bare-metal AVX-512 host for a faster CPU path:
# TEI_MKL_INSTRUCTIONS=AVX512_E4
# Long-context models (e.g. jina-code, max_input_length=8192) can make TEI's
# startup warmup pass take minutes or fail on CPU (default --max-batch-tokens
# 16384). Lower both together for a bounded CPU cold start; keep
# MAX_DENSE_EMBED_TOKENS <= TEI_MAX_BATCH_TOKENS so no single chunk exceeds
# the server-side batch cap:
# TEI_MAX_BATCH_TOKENS=1024
# MAX_DENSE_EMBED_TOKENS=1024

# ---------------------------------------------------------------------------
# MCP server transport (optional; defaults match docker-compose.yml)
# ---------------------------------------------------------------------------
# MCP_TRANSPORT=streamable-http
# MCP_HOST=0.0.0.0
# MCP_PORT=8000
# WORKSPACE_PATH=/workspace

# ---------------------------------------------------------------------------
# Qdrant client (optional overrides)
# ---------------------------------------------------------------------------
# QDRANT_URL=http://localhost:6333
# QDRANT_TIMEOUT=30
# QDRANT_COLLECTION=codebase
# HYBRID_SEARCH=true

# ---------------------------------------------------------------------------
# Recommendation search (ADR 0014; dense-only; no re-index required)
# ---------------------------------------------------------------------------
# RECOMMEND_ENABLED=true
# RECOMMEND_MAX_EXAMPLES=10
# OUTLIER_MAX_CONTEXT_SAMPLES=200
# OUTLIER_MAX_SIMILARITY=0.55

# ---------------------------------------------------------------------------
# Optional ColBERT reranking (ADR 0008; requires full re-index when enabling)
# ---------------------------------------------------------------------------
# RERANK_ENABLED=false
# COLBERT_EMBED_MODEL=colbert-ir/colbertv2.0
# RERANK_PREFETCH=100
# RERANK_MAX_QUERY_TOKENS=0   # 0 = model registry default (512 for colbertv2.0)
# RERANK_ADAPTIVE_ENABLED=true   # probe hybrid RRF gap before ColBERT (when rerank on)
# RERANK_ADAPTIVE_GAP=0.02       # skip ColBERT when rank1 - rank2 RRF score >= gap
# Per-call override: pass rerank=false on search_codebase, search_symbols,
# find_cross_references, or map_service_dependencies to skip ColBERT embed + MAX_SIM.
#
# --- ColBERT sidecar (ADR 0015; default when RERANK_ENABLED=true — ADR 0022 phase 2) ---
# When RERANK_ENABLED=true, compose_files.py adds docker-compose.colbert-worker.yml
# (+ .gpu.yml when ACCELERATOR=gpu). Default backend is remote (GPU sidecar).
# Compose-only (not Python Settings): COLBERT_MEM_LIMIT, COLBERT_CPUS
# COLBERT_EMBED_BACKEND=remote # default when rerank on (GPU sidecar when ACCELERATOR=gpu)
# COLBERT_EMBED_BACKEND=onnx   # in-process CPU ONNX in MCP (ACCELERATOR=cpu only path)
# COLBERT_URL=http://colbert_worker:8082
# COLBERT_TIMEOUT=300
# COLBERT_EMBED_BATCH_SIZE=16
# COLBERT_MEM_LIMIT=4g
# COLBERT_CPUS=4
#
# Example: TEI GPU + ColBERT sidecar + rerank (re-index required when enabling):
#   RERANK_ENABLED=true
#   COLBERT_EMBED_BACKEND=remote
#   MCP_MEM_LIMIT=3g
#   COLBERT_MEM_LIMIT=3g
#   FLUSH_EVERY=96
#   UPSERT_BATCH=10          # required: ColBERT multivectors blow HTTP body limit if too large
#   SEQUENTIAL_EMBED=false
#   docker compose $(python scripts/compose_files.py) --profile bundled-tei up -d --build
#
# --- ColBERT GPU sidecar (ADR 0015 phase 2; default when ACCELERATOR=gpu + remote sidecar) ---
# Compose-only: COLBERT_GPU, COLBERT_GPU_COUNT, COLBERT_DEVICE_IDS
# Requires NVIDIA Container Toolkit. Uses colbert_worker/Dockerfile.gpu.
#   COLBERT_GPU=1
#   COLBERT_GPU_COUNT=1
#   COLBERT_USE_CUDA=1         # set automatically by docker-compose.colbert-worker.gpu.yml
#   COLBERT_DEVICE_IDS=0       # optional comma-separated GPU indices
# On a single 8 GB GPU, TEI + ColBERT may OOM — use a second GPU or CPU ColBERT sidecar.

# ---------------------------------------------------------------------------
# Optional GraphRAG / Neo4j (ADR 0002 Phase 1; requires full re-index when enabling)
# ---------------------------------------------------------------------------
# Disabled by default — no Neo4j driver init or graph I/O unless GRAPH_ENABLED=true.
# Phase 1 writes a code graph at index time (Chunk, File, Symbol, IMPORTS, CALLS, …).
# Phase 2–3 (graph_node_ids in Qdrant, expand_search_context tool) not shipped yet.
#
# GRAPH_ENABLED=false
# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=          # required when GRAPH_ENABLED=true (compose fails fast if missing)
# NEO4J_DATABASE=neo4j
# GRAPH_WRITER_BATCH=500
# Re-index collections after graph writer / Neo4j ontology changes (no version env var).
# ADR 0023 Phase 2: graph-enabled indexing omits Qdrant callees payloads and stamps
# collection metadata graph_call_sites=true — force re-index when enabling graph.
# GRAPH_MAX_HOPS=2         # Phase 3 retrieval default (not used in Phase 1)
# GRAPH_MAX_NODES=200      # Phase 3 subgraph cap (not used in Phase 1)
#
# Compose-only (not Python Settings): NEO4J_MEM_LIMIT, NEO4J_CPUS
# NEO4J_MEM_LIMIT=2g
# NEO4J_CPUS=2
#
# Recommended stack (bundled TEI + Neo4j):
#   COMPOSE_PROFILES=bundled-tei
#   TEI_URL=http://tei:80
#   GRAPH_ENABLED=true
#   NEO4J_PASSWORD=change-me-to-a-secure-password
#   docker compose -f docker-compose.yml -f docker-compose.tei.yml \
#     -f docker-compose.neo4j.yml --profile bundled-tei up -d --build
#
# After first Neo4j start, NEO4J_PASSWORD is stored in the neo4j_data volume.
# Changing .env alone does not rotate the password — reset the volume if needed:
#   docker compose ... stop mcp_server cron neo4j
#   docker rm codeindexer_neo4j && docker volume rm codebase-indexer-mcp_neo4j_data
#   docker compose ... up -d neo4j mcp_server cron
#
# Re-index each collection when enabling graph on existing Qdrant data:
#   index_codebase(path='<project-folder>', force=True, wait=True)
#   # or from repo root: python scripts/reindex_graphrag.py
#
# Neo4j Browser (local): http://127.0.0.1:7474  (user NEO4J_USER, password NEO4J_PASSWORD)

# ---------------------------------------------------------------------------
# Model / chunking (optional overrides)
# ---------------------------------------------------------------------------
# HF_HUB_OFFLINE=1   # use after first successful start (models cached in volume)
# HF_HOME=/path/to/huggingface   # optional: persistent cache for dense tokenizer files (ADR 0017)
# BGE English v1.5 (BAAI official — both use 512 max sequence length):
#   bge-base-en-v1.5  → DENSE_EMBED_VECTOR_SIZE=768
#   bge-small-en-v1.5 → DENSE_EMBED_VECTOR_SIZE=384
# MAX_DENSE_EMBED_TOKENS=0   # 0 = auto-detect (512 for BGE base/small; 32768 for Qwen3; 8192 for nomic)
#                            # Or set MAX_DENSE_EMBED_TOKENS=512 explicitly for BGE
# MAX_SPARSE_EMBED_TOKENS=0  # 0 = no sparse truncation (default for Qdrant/bm25)
# MAX_CHUNK_LINES=150
# CHUNK_OVERLAP_LINES=20
# EXCLUDED_DIRS=node_modules,.git,__pycache__,.venv,venv,dist,build,target,bin,obj,.gradle,.mypy_cache,.pytest_cache,.ruff_cache,.github,.idea,.vscode,migrations
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# By default the MCP server and Qdrant are published on 127.0.0.1 only, so they
# are not reachable from the LAN. If you change the port binding to expose the
# server beyond localhost, set a bearer token below. When set, every HTTP
# request (except /health) must send `Authorization: Bearer <token>`. The
# HTTP clients pass it via mcp.json headers; the stdio sidecar proxy reads
# the same value from env automatically.
# MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# Application metrics (ADR 0018 Phase 1; opt-in Prometheus scrape)
# ---------------------------------------------------------------------------
# METRICS_ENABLED=false   # default — no /metrics route, zero overhead
# When true, MCP exposes GET /metrics on the same port as streamable-http (MCP_PORT).
# With MCP_AUTH_TOKEN set, /metrics requires the same Bearer token as other routes
# (except /health). ColBERT sidecar: set METRICS_ENABLED=true in colbert_worker env;
# /metrics is loopback-only (127.0.0.1:8082) — not published beyond localhost in default compose.

# ---------------------------------------------------------------------------
# CPU / threading (sparse BM25; OMP_NUM_THREADS also caps BLAS in container)
# ---------------------------------------------------------------------------
# SPARSE_THREADS=2 is tuned for Qdrant/bm25 (default).

# ---------------------------------------------------------------------------
# Pipeline batching (higher = faster + more RAM; the double buffer holds ~2x
# FLUSH_EVERY chunks at peak)
# ---------------------------------------------------------------------------
# BATCH_SIZE=32
# FLUSH_EVERY=1500
# UPSERT_BATCH=500          # OK for dense+sparse only
# UPSERT_BATCH=10           # use 10-25 when RERANK_ENABLED=true (ColBERT multivectors)
# READAHEAD_BUFFER=100
# MAX_DENSE_EMBED_TOKENS=2048
# See docs/DEPLOYMENT.md#colbert-rerank-qdrant-upsert-batching if upserts fail with empty errors.

# ---------------------------------------------------------------------------
# glibc memory tuning (cuts threaded sparse-ONNX RSS bloat; leave as-is unless you
# know what you're doing)
# ---------------------------------------------------------------------------
# MALLOC_ARENA_MAX=2
# MALLOC_TRIM_THRESHOLD_=131072

# ---------------------------------------------------------------------------
# Sparse BM25 model lifecycle (RAM reclamation after indexing / idle periods)
# ---------------------------------------------------------------------------
# Release ONNX models after each index job (default: true). Reclaims ~300-500 MB
# of native memory immediately. Models reload in ~1.5s from the fastembed_cache
# volume on the next search query. Set to false only for sub-second search
# latency right after indexing.
# RELEASE_MODELS_AFTER_INDEX=true

# Seconds of embed inactivity before ONNX models are auto-released (default: 300).
# Reclaims memory when the server is idle after search queries, not just indexing.
# Set to 0 to disable the idle timer and keep models loaded indefinitely.
# MODEL_IDLE_TIMEOUT=300

# Eagerly probe TEI and load sparse BM25 during startup (default: true). Set PRELOAD_MODELS=false
# to defer loading until the first embed request — useful when TEI starts after MCP or on
# memory-constrained hosts that should not warm models at boot.
# PRELOAD_MODELS=true

# ---------------------------------------------------------------------------
# Embedding concurrency (peak RAM vs throughput during indexing)
# Run sparse then dense sequentially instead of asyncio.gather (default: false).
# ~40-50% slower indexing but ~50% lower peak memory on constrained hosts.
# SEQUENTIAL_EMBED=false

# ---------------------------------------------------------------------------
# Memory pressure thresholds (cgroup-aware OOM prevention)
# At warn_pct: batch size is halved and dense/sparse run sequentially.
# At halt_pct: the current flush is aborted with a clear error message
# instead of being silently OOM-killed.
# ---------------------------------------------------------------------------
# MEMORY_PRESSURE_WARN_PCT=70
# MEMORY_PRESSURE_HALT_PCT=85

# ---------------------------------------------------------------------------
# Qdrant storage (RAM vs search speed). Changing these re-creates collections,
# so they take effect on the next (re-)index of each project.
# ---------------------------------------------------------------------------
# VECTORS_ON_DISK=true       # memory-map dense vectors instead of RAM-resident
# SPARSE_ON_DISK=true        # store sparse vector index on disk
# QUANTIZATION=true          # int8 dense vectors (~4x less RAM, rescored)
# MEMMAP_THRESHOLD_KB=20000  # segments above this size are memory-mapped
# PAYLOAD_INDEXES=true       # keyword indexes on rel_path, chunk_id, symbol_name, language

# ---------------------------------------------------------------------------
# Qdrant search / HNSW tuning (query-time; takes effect immediately)
# ---------------------------------------------------------------------------
# QUANT_OVERSAMPLING=2.0     # quantized dense oversampling before rescore (quantization=true)
# HNSW_EF=64                 # query-time HNSW search breadth (higher = better recall, slower)
# HNSW_M=16                  # HNSW graph degree at build time (higher = better recall, more RAM)
# HNSW_EF_CONSTRUCT=128      # HNSW construction breadth (higher = better graph, slower build)
# PREFETCH_MULTIPLIER=5      # hybrid prefetch limit = top_k * multiplier per channel
# RRF_K=60                   # RRF constant for multi-collection result re-fusion

# ---------------------------------------------------------------------------
# Service mapping / cross-references (optional)
# ---------------------------------------------------------------------------
# SERVICE_URL_KEYWORDS=rest,api,profile,service,internal,public,gateway,graphql,webhook,auth,users,accounts
# SERVICE_DISCOVERY_EXTRA_QUERIES=   # pipe (|) or newline-separated extra map_service_dependencies queries

# ---------------------------------------------------------------------------
# Cron reindex timeouts (codeindexer_cron / cron/reindex.py)
# ---------------------------------------------------------------------------
# MCP_URL=http://mcp_server:8000
# INDEX_TIMEOUT=1800
# MCP_HTTP_TIMEOUT=300
# GIT_TIMEOUT=120

# ---------------------------------------------------------------------------
# Benchmark harness (mcp_server/benchmarks/bench.py — env defaults for CLI)
# ---------------------------------------------------------------------------
# BENCH_FILES=300
# BENCH_SEED=1234
# BENCH_ITERS=50
# BENCH_COLLECTION=benchproj
# BENCH_THRESHOLD=0

# ===========================================================================
# TUNING PRESETS — replace the REQUIRED block above with one of these
# ===========================================================================

# --- BGE base v1.5 (768 dim, 512 tokens) ---
# DENSE_EMBED_MODEL=BAAI/bge-base-en-v1.5
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_EMBED_MODEL=Qdrant/bm25
# SPARSE_THREADS=2
# MAX_DENSE_EMBED_TOKENS=0

# --- BGE small v1.5 (384 dim, 512 tokens; less RAM than base) ---
# DENSE_EMBED_MODEL=BAAI/bge-small-en-v1.5
# DENSE_EMBED_VECTOR_SIZE=384
# SPARSE_EMBED_MODEL=Qdrant/bm25
# SPARSE_THREADS=2
# MAX_DENSE_EMBED_TOKENS=0

# --- 16C / 16GB (balanced) ---
# WORKSPACE_ROOT=C:\Users\me\repos
# MCP_MEM_LIMIT=9g
# QDRANT_MEM_LIMIT=5g
# MCP_CPUS=14
# QDRANT_CPUS=4
# OMP_NUM_THREADS=12
# DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# SPARSE_EMBED_MODEL=Qdrant/bm25
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_THREADS=2

# --- 8C / 8GB (low memory) ---
# WORKSPACE_ROOT=C:\Users\me\repos
# DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# SPARSE_EMBED_MODEL=Qdrant/bm25
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_THREADS=2
# MCP_MEM_LIMIT=5g
# QDRANT_MEM_LIMIT=2g
# MCP_CPUS=7
# QDRANT_CPUS=2
# OMP_NUM_THREADS=6
# BATCH_SIZE=16
# FLUSH_EVERY=750
# VECTORS_ON_DISK=true
# QUANTIZATION=true

# --- 32C / 64GB (high throughput) ---
# WORKSPACE_ROOT=C:\Users\me\repos
# DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# SPARSE_EMBED_MODEL=Qdrant/bm25
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_THREADS=2
# MCP_MEM_LIMIT=40g
# QDRANT_MEM_LIMIT=20g
# MCP_CPUS=28
# QDRANT_CPUS=4
# OMP_NUM_THREADS=24
# BATCH_SIZE=64
# FLUSH_EVERY=4000
# VECTORS_ON_DISK=false   # keep vectors in RAM for fastest search
# QUANTIZATION=false      # plenty of RAM; skip quantization for max fidelity

# --- TEI GPU optimal — Jina code (production default) ---
# COMPOSE_PROFILES=bundled-tei
# TEI_GPU=1
# TEI_GPU_COUNT=1
# DENSE_EMBED_MODEL=jinaai/jina-embeddings-v2-base-code
# DENSE_EMBED_VECTOR_SIZE=768
# MCP_MEM_LIMIT=2g
# MCP_CPUS=14
# QDRANT_MEM_LIMIT=2g
# QDRANT_CPUS=2
# OMP_NUM_THREADS=4
# SPARSE_EMBED_MODEL=Qdrant/bm25
# SPARSE_THREADS=2
# BATCH_SIZE=32
# FLUSH_EVERY=2048
# MAX_DENSE_EMBED_TOKENS=1024
#
# --- Experimental / CoIR preset — Qwen3-4B @ 1024 (16C / 16GB host + NVIDIA 8GB VRAM) ---
# WARNING: −63.1% recall@10 vs Jina on this repo's golden set (ADR 0016). CoIR rank alone
# does not predict retrieval quality here. Full re-index @ 1024 MRL required.
# Start: docker compose -f docker-compose.yml -f docker-compose.tei.yml \
#   -f docker-compose.tei.gpu.yml up -d --build
# docker exec codeindexer_tei TEI loads model at startup Qwen/Qwen3-Embedding-4B
# COMPOSE_PROFILES=bundled-tei
# TEI_GPU=1
# TEI_GPU_COUNT=1
# DENSE_EMBED_MODEL=Qwen/Qwen3-Embedding-4B
# DENSE_EMBED_VECTOR_SIZE=1024
# MCP_MEM_LIMIT=4g
# MCP_CPUS=14
# QDRANT_MEM_LIMIT=2g
# QDRANT_CPUS=2
# OMP_NUM_THREADS=4
# SPARSE_EMBED_MODEL=Qdrant/bm25
# SPARSE_THREADS=2
# BATCH_SIZE=32
# FLUSH_EVERY=2048
# Memory-pressure guard (MEMORY_PRESSURE_*_PCT) tracks container RAM, not TEI GPU VRAM.
# If TEI runs out of memory, lower BATCH_SIZE, TEI_MEM_LIMIT, and/or MAX_DENSE_EMBED_TOKENS.
