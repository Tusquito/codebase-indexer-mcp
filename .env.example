# Copy this file to .env and set WORKSPACE_ROOT to your repos directory.
# All other settings have defaults in docker-compose.yml — only override here if needed.

# REQUIRED: mount this directory as /workspace inside the container.
# Set to your repos parent directory to index multiple projects.
# Each subdirectory becomes a separate collection automatically.
WORKSPACE_ROOT=C:\Users\me\repos

# Optional overrides (defaults are set in docker-compose.yml):
# HF_HUB_OFFLINE=1   # use after first successful start (models cached in fastembed volume)
# EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# VECTOR_SIZE=768
# BATCH_SIZE=32
# MAX_CHUNK_LINES=150
# CHUNK_OVERLAP_LINES=20
# LOG_LEVEL=INFO
