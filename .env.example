# Copy this file to .env and fill in the REQUIRED section for your machine.
# Docker Compose fails fast if any required variable is missing.
# Optional settings below override application defaults in config.py when set in .env.
# Docker Compose passes all Settings fields into mcp_server — see docs/DEPLOYMENT.md
# ("Docker Compose env passthrough"). Restart mcp_server after env-only changes.

# ===========================================================================
# REQUIRED — set these before `docker compose up`
# ===========================================================================

# Parent directory of all repos to index (mounted read-only as /workspace).
# Each direct subdirectory becomes a separate collection.
WORKSPACE_ROOT=C:\Users\me\repos

# Container resource caps (must fit your Docker VM; leave 2–3 GiB for kernel/WSL).
# Example values below target 16 CPU / 16 GB — see TUNING PRESETS to swap.
MCP_MEM_LIMIT=9g
QDRANT_MEM_LIMIT=5g
MCP_CPUS=14
QDRANT_CPUS=4
OMP_NUM_THREADS=12

# Embedding models (changing these requires a full re-index).
DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
SPARSE_EMBED_MODEL=Qdrant/bm25
DENSE_EMBED_VECTOR_SIZE=768
# ONNX threads for the sparse encoder (tune to SPARSE_EMBED_MODEL).
SPARSE_THREADS=2
#
# --- Ollama dense (required; sparse BM25 stays in MCP) ---
# Compose-only (not Python Settings): COMPOSE_PROFILES, OLLAMA_GPU, OLLAMA_PORT, OLLAMA_MEM_LIMIT, OLLAMA_CPUS
# Bundled Ollama service in Compose (recommended):
#   COMPOSE_PROFILES=bundled-ollama
#   OLLAMA_URL=http://ollama:11434
# External Ollama on the host instead (native install or your own container):
#   COMPOSE_PROFILES=
#   OLLAMA_URL=http://host.docker.internal:11434
# Ollama GPU (bundled service only; requires NVIDIA Container Toolkit):
#   OLLAMA_GPU=1
#   OLLAMA_GPU_COUNT=1
#   Add compose override: -f docker-compose.ollama.gpu.yml
# OLLAMA_EMBED_MODEL=unclemusclez/jina-embeddings-v2-base-code
# OLLAMA_EMBED_BATCH_SIZE=32
# OLLAMA_TIMEOUT=120
# OLLAMA_PORT=11434
# OLLAMA_MEM_LIMIT=4g
# OLLAMA_CPUS=4

# ---------------------------------------------------------------------------
# MCP server transport (optional; defaults match docker-compose.yml)
# ---------------------------------------------------------------------------
# MCP_TRANSPORT=streamable-http
# MCP_HOST=0.0.0.0
# MCP_PORT=8000
# WORKSPACE_PATH=/workspace

# ---------------------------------------------------------------------------
# Qdrant client (optional overrides)
# ---------------------------------------------------------------------------
# QDRANT_URL=http://localhost:6333
# QDRANT_TIMEOUT=30
# QDRANT_COLLECTION=codebase
# HYBRID_SEARCH=true

# ---------------------------------------------------------------------------
# Optional ColBERT reranking (ADR 0008; requires full re-index when enabling)
# ---------------------------------------------------------------------------
# RERANK_ENABLED=false
# COLBERT_EMBED_MODEL=colbert-ir/colbertv2.0
# RERANK_PREFETCH=100
# RERANK_MAX_QUERY_TOKENS=0   # 0 = model registry default (512 for colbertv2.0)
#
# --- ColBERT sidecar (ADR 0015; optional; offloads ColBERT RAM from MCP) ---
# Compose-only (not Python Settings): COLBERT_MEM_LIMIT, COLBERT_CPUS
# Add compose override: -f docker-compose.colbert-worker.yml
# COLBERT_EMBED_BACKEND=onnx   # default: in-process fastembed ONNX in MCP
# COLBERT_EMBED_BACKEND=remote # HTTP sidecar (requires docker-compose.colbert-worker.yml)
# COLBERT_URL=http://colbert_worker:8082
# COLBERT_TIMEOUT=300
# COLBERT_EMBED_BATCH_SIZE=16
# COLBERT_MEM_LIMIT=4g
# COLBERT_CPUS=4
#
# Example: Ollama GPU + ColBERT sidecar + rerank (re-index required when enabling):
#   RERANK_ENABLED=true
#   COLBERT_EMBED_BACKEND=remote
#   MCP_MEM_LIMIT=3g
#   COLBERT_MEM_LIMIT=3g
#   FLUSH_EVERY=96
#   UPSERT_BATCH=10          # required: ColBERT multivectors blow HTTP body limit if too large
#   SEQUENTIAL_EMBED=false
#   docker compose -f docker-compose.yml -f docker-compose.ollama.yml \
#     -f docker-compose.ollama.gpu.yml -f docker-compose.colbert-worker.yml up -d --build

# ---------------------------------------------------------------------------
# Model / chunking (optional overrides)
# ---------------------------------------------------------------------------
# HF_HUB_OFFLINE=1   # use after first successful start (models cached in volume)
# BGE English v1.5 (BAAI official — both use 512 max sequence length):
#   bge-base-en-v1.5  → DENSE_EMBED_VECTOR_SIZE=768
#   bge-small-en-v1.5 → DENSE_EMBED_VECTOR_SIZE=384
# MAX_DENSE_EMBED_TOKENS=0   # 0 = auto-detect (512 for BGE base/small; 8192 for nomic)
#                            # Or set MAX_DENSE_EMBED_TOKENS=512 explicitly for BGE
# MAX_SPARSE_EMBED_TOKENS=0  # 0 = no sparse truncation (default for Qdrant/bm25)
# MAX_CHUNK_LINES=150
# CHUNK_OVERLAP_LINES=20
# EXCLUDED_DIRS=node_modules,.git,__pycache__,.venv,venv,dist,build,target,bin,obj,.gradle,.mypy_cache,.pytest_cache,.ruff_cache,.github,.idea,.vscode,migrations
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# By default the MCP server and Qdrant are published on 127.0.0.1 only, so they
# are not reachable from the LAN. If you change the port binding to expose the
# server beyond localhost, set a bearer token below. When set, every HTTP
# request (except /health) must send `Authorization: Bearer <token>`. The
# HTTP clients pass it via mcp.json headers; the stdio sidecar proxy reads
# the same value from env automatically.
# MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# CPU / threading (sparse BM25; OMP_NUM_THREADS also caps BLAS in container)
# ---------------------------------------------------------------------------
# SPARSE_THREADS=2 is tuned for Qdrant/bm25 (default).

# ---------------------------------------------------------------------------
# Pipeline batching (higher = faster + more RAM; the double buffer holds ~2x
# FLUSH_EVERY chunks at peak)
# ---------------------------------------------------------------------------
# BATCH_SIZE=32
# FLUSH_EVERY=1500
# UPSERT_BATCH=500          # OK for dense+sparse only
# UPSERT_BATCH=10           # use 10-25 when RERANK_ENABLED=true (ColBERT multivectors)
# READAHEAD_BUFFER=100
# MAX_DENSE_EMBED_TOKENS=2048
# See docs/DEPLOYMENT.md#colbert-rerank-qdrant-upsert-batching if upserts fail with empty errors.

# ---------------------------------------------------------------------------
# glibc memory tuning (cuts threaded sparse-ONNX RSS bloat; leave as-is unless you
# know what you're doing)
# ---------------------------------------------------------------------------
# MALLOC_ARENA_MAX=2
# MALLOC_TRIM_THRESHOLD_=131072

# ---------------------------------------------------------------------------
# Sparse BM25 model lifecycle (RAM reclamation after indexing / idle periods)
# ---------------------------------------------------------------------------
# Release ONNX models after each index job (default: true). Reclaims ~300-500 MB
# of native memory immediately. Models reload in ~1.5s from the fastembed_cache
# volume on the next search query. Set to false only for sub-second search
# latency right after indexing.
# RELEASE_MODELS_AFTER_INDEX=true

# Seconds of embed inactivity before ONNX models are auto-released (default: 300).
# Reclaims memory when the server is idle after search queries, not just indexing.
# Set to 0 to disable the idle timer and keep models loaded indefinitely.
# MODEL_IDLE_TIMEOUT=300

# Eagerly probe Ollama and load sparse BM25 during startup (default: true). Set PRELOAD_MODELS=false
# to defer loading until the first embed request — useful when Ollama starts after MCP or on
# memory-constrained hosts that should not warm models at boot.
# PRELOAD_MODELS=true

# ---------------------------------------------------------------------------
# Embedding concurrency (peak RAM vs throughput during indexing)
# Run sparse then dense sequentially instead of asyncio.gather (default: false).
# ~40-50% slower indexing but ~50% lower peak memory on constrained hosts.
# SEQUENTIAL_EMBED=false

# ---------------------------------------------------------------------------
# Memory pressure thresholds (cgroup-aware OOM prevention)
# At warn_pct: batch size is halved and dense/sparse run sequentially.
# At halt_pct: the current flush is aborted with a clear error message
# instead of being silently OOM-killed.
# ---------------------------------------------------------------------------
# MEMORY_PRESSURE_WARN_PCT=70
# MEMORY_PRESSURE_HALT_PCT=85

# ---------------------------------------------------------------------------
# Qdrant storage (RAM vs search speed). Changing these re-creates collections,
# so they take effect on the next (re-)index of each project.
# ---------------------------------------------------------------------------
# VECTORS_ON_DISK=true       # memory-map dense vectors instead of RAM-resident
# SPARSE_ON_DISK=true        # store sparse vector index on disk
# QUANTIZATION=true          # int8 dense vectors (~4x less RAM, rescored)
# MEMMAP_THRESHOLD_KB=20000  # segments above this size are memory-mapped
# PAYLOAD_INDEXES=true       # keyword indexes on rel_path, chunk_id, symbol_name, language

# ---------------------------------------------------------------------------
# Qdrant search / HNSW tuning (query-time; takes effect immediately)
# ---------------------------------------------------------------------------
# QUANT_OVERSAMPLING=2.0     # quantized dense oversampling before rescore (quantization=true)
# HNSW_EF=64                 # query-time HNSW search breadth (higher = better recall, slower)
# HNSW_M=16                  # HNSW graph degree at build time (higher = better recall, more RAM)
# HNSW_EF_CONSTRUCT=128      # HNSW construction breadth (higher = better graph, slower build)
# PREFETCH_MULTIPLIER=5      # hybrid prefetch limit = top_k * multiplier per channel
# RRF_K=60                   # RRF constant for multi-collection result re-fusion

# ---------------------------------------------------------------------------
# Service mapping / cross-references (optional)
# ---------------------------------------------------------------------------
# SERVICE_URL_KEYWORDS=rest,api,profile,service,internal,public,gateway,graphql,webhook,auth,users,accounts
# SERVICE_DISCOVERY_EXTRA_QUERIES=   # pipe (|) or newline-separated extra map_service_dependencies queries

# ---------------------------------------------------------------------------
# Cron reindex timeouts (codeindexer_cron / cron/reindex.py)
# ---------------------------------------------------------------------------
# MCP_URL=http://mcp_server:8000
# INDEX_TIMEOUT=1800
# MCP_HTTP_TIMEOUT=300
# GIT_TIMEOUT=120

# ---------------------------------------------------------------------------
# Benchmark harness (mcp_server/benchmarks/bench.py — env defaults for CLI)
# ---------------------------------------------------------------------------
# BENCH_FILES=300
# BENCH_SEED=1234
# BENCH_ITERS=50
# BENCH_COLLECTION=benchproj
# BENCH_THRESHOLD=0

# ===========================================================================
# TUNING PRESETS — replace the REQUIRED block above with one of these
# ===========================================================================

# --- BGE base v1.5 (768 dim, 512 tokens) ---
# DENSE_EMBED_MODEL=BAAI/bge-base-en-v1.5
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_EMBED_MODEL=Qdrant/bm25
# SPARSE_THREADS=2
# MAX_DENSE_EMBED_TOKENS=0

# --- BGE small v1.5 (384 dim, 512 tokens; less RAM than base) ---
# DENSE_EMBED_MODEL=BAAI/bge-small-en-v1.5
# DENSE_EMBED_VECTOR_SIZE=384
# SPARSE_EMBED_MODEL=Qdrant/bm25
# SPARSE_THREADS=2
# MAX_DENSE_EMBED_TOKENS=0

# --- 16C / 16GB (balanced) ---
# WORKSPACE_ROOT=C:\Users\me\repos
# MCP_MEM_LIMIT=9g
# QDRANT_MEM_LIMIT=5g
# MCP_CPUS=14
# QDRANT_CPUS=4
# OMP_NUM_THREADS=12
# DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# SPARSE_EMBED_MODEL=Qdrant/bm25
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_THREADS=2

# --- 8C / 8GB (low memory) ---
# WORKSPACE_ROOT=C:\Users\me\repos
# DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# SPARSE_EMBED_MODEL=Qdrant/bm25
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_THREADS=2
# MCP_MEM_LIMIT=5g
# QDRANT_MEM_LIMIT=2g
# MCP_CPUS=7
# QDRANT_CPUS=2
# OMP_NUM_THREADS=6
# BATCH_SIZE=16
# FLUSH_EVERY=750
# VECTORS_ON_DISK=true
# QUANTIZATION=true

# --- 32C / 64GB (high throughput) ---
# WORKSPACE_ROOT=C:\Users\me\repos
# DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# SPARSE_EMBED_MODEL=Qdrant/bm25
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_THREADS=2
# MCP_MEM_LIMIT=40g
# QDRANT_MEM_LIMIT=20g
# MCP_CPUS=28
# QDRANT_CPUS=4
# OMP_NUM_THREADS=24
# BATCH_SIZE=64
# FLUSH_EVERY=4000
# VECTORS_ON_DISK=false   # keep vectors in RAM for fastest search
# QUANTIZATION=false      # plenty of RAM; skip quantization for max fidelity

# --- Ollama GPU optimal — medium tier (16C / 16GB host + NVIDIA 8GB VRAM, e.g. RTX 4060 Ti) ---
# Tested preset: Jina code dense via Ollama GPU + BM25 sparse on CPU.
# Start: docker compose -f docker-compose.yml -f docker-compose.ollama.yml \
#   -f docker-compose.ollama.gpu.yml up -d --build
# COMPOSE_PROFILES=bundled-ollama
# OLLAMA_GPU=1
# OLLAMA_GPU_COUNT=1
# OLLAMA_EMBED_MODEL=unclemusclez/jina-embeddings-v2-base-code
# MCP_MEM_LIMIT=2g   # measured peak ~235 MB (udh-engine 11k chunks); raise if MEMORY_PRESSURE halt fires
# MCP_CPUS=14
# QDRANT_MEM_LIMIT=2g
# QDRANT_CPUS=2
# OMP_NUM_THREADS=4
# DENSE_EMBED_MODEL=jinaai/jina-embeddings-v2-base-code
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_EMBED_MODEL=Qdrant/bm25
# SPARSE_THREADS=2
# BATCH_SIZE=32
# FLUSH_EVERY=2048
# MAX_DENSE_EMBED_TOKENS=1024
# Memory-pressure guard (MEMORY_PRESSURE_*_PCT) tracks container RAM, not Ollama GPU VRAM.
# If Ollama runs out of memory, lower BATCH_SIZE, OLLAMA_MEM_LIMIT, and/or MAX_DENSE_EMBED_TOKENS.
