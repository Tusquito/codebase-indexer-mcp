# Copy this file to .env and fill in the REQUIRED section for your machine.
# Docker Compose fails fast if any required variable is missing.
# Optional settings below override application defaults in config.py.

# ===========================================================================
# REQUIRED — set these before `docker compose up`
# ===========================================================================

# Parent directory of all repos to index (mounted read-only as /workspace).
# Each direct subdirectory becomes a separate collection.
WORKSPACE_ROOT=C:\Users\me\repos

# Container resource caps (must fit your Docker VM; leave 2–3 GiB for kernel/WSL).
# Example values below target 16 CPU / 16 GB — see TUNING PRESETS to swap.
MCP_MEM_LIMIT=9g
QDRANT_MEM_LIMIT=5g
MCP_CPUS=14
QDRANT_CPUS=4
OMP_NUM_THREADS=12

# Embedding models (changing these requires a full re-index).
DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
SPARSE_EMBED_MODEL=Qdrant/bm25
DENSE_EMBED_VECTOR_SIZE=768
# ONNX threads for the sparse encoder (tune to SPARSE_EMBED_MODEL).
SPARSE_THREADS=2

# ---------------------------------------------------------------------------
# Model / chunking (optional overrides)
# ---------------------------------------------------------------------------
# HF_HUB_OFFLINE=1   # use after first successful start (models cached in volume)
# Alt dense: BAAI/bge-base-en-v1.5 (768), BAAI/bge-small-en-v1.5 (384) — set matching DENSE_EMBED_VECTOR_SIZE
# Alt sparse: prithivida/Splade_PP_en_v1  (SPLADE++ — learned sparse, better quality, heavier CPU)
# MAX_CHUNK_LINES=150
# CHUNK_OVERLAP_LINES=20
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# By default the MCP server and Qdrant are published on 127.0.0.1 only, so they
# are not reachable from the LAN. If you change the port binding to expose the
# server beyond localhost, set a bearer token below. When set, every HTTP
# request (except /health) must send `Authorization: Bearer <token>`. The
# in-container stdio proxy reads the same value automatically.
# MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# CPU / threading (dense encoder optional; sparse required above)
# ---------------------------------------------------------------------------
# DENSE_THREADS=0
# With prithivida/Splade_PP_en_v1 use SPARSE_THREADS=4 or higher.

# ---------------------------------------------------------------------------
# Pipeline batching (higher = faster + more RAM; the double buffer holds ~2x
# FLUSH_EVERY chunks at peak)
# ---------------------------------------------------------------------------
# BATCH_SIZE=32
# FLUSH_EVERY=1500
# UPSERT_BATCH=500
# READAHEAD_BUFFER=100
# MAX_EMBED_CHARS=4096

# ---------------------------------------------------------------------------
# glibc memory tuning (cuts threaded-ONNX RSS bloat; leave as-is unless you
# know what you're doing)
# ---------------------------------------------------------------------------
# MALLOC_ARENA_MAX=2
# MALLOC_TRIM_THRESHOLD_=131072

# ---------------------------------------------------------------------------
# ONNX model lifecycle (RAM reclamation after indexing / idle periods)
# ---------------------------------------------------------------------------
# Release ONNX models after each index job (default: true). Reclaims ~300-500 MB
# of native memory immediately. Models reload in ~1.5s from the fastembed_cache
# volume on the next search query. Set to false only for sub-second search
# latency right after indexing.
# RELEASE_MODELS_AFTER_INDEX=true

# Seconds of embed inactivity before ONNX models are auto-released (default: 300).
# Reclaims memory when the server is idle after search queries, not just indexing.
# Set to 0 to disable the idle timer and keep models loaded indefinitely.
# MODEL_IDLE_TIMEOUT=300

# ---------------------------------------------------------------------------
# Memory pressure thresholds (cgroup-aware OOM prevention)
# At warn_pct: batch size is halved and dense/sparse run sequentially.
# At halt_pct: the current flush is aborted with a clear error message
# instead of being silently OOM-killed.
# ---------------------------------------------------------------------------
# MEMORY_PRESSURE_WARN_PCT=70
# MEMORY_PRESSURE_HALT_PCT=85

# ---------------------------------------------------------------------------
# Qdrant storage (RAM vs search speed). Changing these re-creates collections,
# so they take effect on the next (re-)index of each project.
# ---------------------------------------------------------------------------
# VECTORS_ON_DISK=true       # memory-map dense vectors instead of RAM-resident
# SPARSE_ON_DISK=true        # store sparse vector index on disk
# QUANTIZATION=true          # int8 dense vectors (~4x less RAM, rescored)
# MEMMAP_THRESHOLD_KB=20000  # segments above this size are memory-mapped

# ===========================================================================
# TUNING PRESETS — replace the REQUIRED block above with one of these
# ===========================================================================

# --- 16C / 16GB (balanced) ---
# WORKSPACE_ROOT=C:\Users\me\repos
# MCP_MEM_LIMIT=9g
# QDRANT_MEM_LIMIT=5g
# MCP_CPUS=14
# QDRANT_CPUS=4
# OMP_NUM_THREADS=12
# DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# SPARSE_EMBED_MODEL=Qdrant/bm25
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_THREADS=2

# --- 8C / 8GB (low memory) ---
# WORKSPACE_ROOT=C:\Users\me\repos
# DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# SPARSE_EMBED_MODEL=Qdrant/bm25
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_THREADS=2
# MCP_MEM_LIMIT=5g
# QDRANT_MEM_LIMIT=2g
# MCP_CPUS=7
# QDRANT_CPUS=2
# OMP_NUM_THREADS=6
# BATCH_SIZE=16
# FLUSH_EVERY=750
# VECTORS_ON_DISK=true
# QUANTIZATION=true

# --- 32C / 64GB (high throughput) ---
# WORKSPACE_ROOT=C:\Users\me\repos
# DENSE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# SPARSE_EMBED_MODEL=Qdrant/bm25
# DENSE_EMBED_VECTOR_SIZE=768
# SPARSE_THREADS=2
# MCP_MEM_LIMIT=40g
# QDRANT_MEM_LIMIT=20g
# MCP_CPUS=28
# QDRANT_CPUS=4
# OMP_NUM_THREADS=24
# BATCH_SIZE=64
# FLUSH_EVERY=4000
# VECTORS_ON_DISK=false   # keep vectors in RAM for fastest search
# QUANTIZATION=false      # plenty of RAM; skip quantization for max fidelity
