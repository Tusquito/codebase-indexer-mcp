# Copy this file to .env and set WORKSPACE_ROOT to your repos directory.
# All settings have defaults in docker-compose.yml — only override here if needed.
# The defaults are tuned for a 16 CPU / 16 GB machine (balanced profile).

# REQUIRED: mount this directory as /workspace inside the container.
# Set to your repos parent directory to index multiple projects.
# Each subdirectory becomes a separate collection automatically.
WORKSPACE_ROOT=C:\Users\me\repos

# ---------------------------------------------------------------------------
# Model / chunking (rarely changed; changing EMBED_MODEL/VECTOR_SIZE re-indexes)
# ---------------------------------------------------------------------------
# HF_HUB_OFFLINE=1   # use after first successful start (models cached in volume)
# EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
# VECTOR_SIZE=768
# MAX_CHUNK_LINES=150
# CHUNK_OVERLAP_LINES=20
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Container resource caps (per service). Raise these on bigger machines.
# ---------------------------------------------------------------------------
# MCP_MEM_LIMIT=9g
# QDRANT_MEM_LIMIT=5g
# MCP_CPUS=14
# QDRANT_CPUS=4

# ---------------------------------------------------------------------------
# CPU / threading
# ---------------------------------------------------------------------------
# ONNX/BLAS threads per encoder. Keep at/below physical cores; dense + sparse
# encoders run concurrently. DENSE_THREADS/SPARSE_THREADS override per-encoder
# (0 = auto: ~75% of CPU cores, leaving headroom for Qdrant + the event loop).
# OMP_NUM_THREADS=12
# DENSE_THREADS=0
# SPARSE_THREADS=0

# ---------------------------------------------------------------------------
# Pipeline batching (higher = faster + more RAM; the double buffer holds ~2x
# FLUSH_EVERY chunks at peak)
# ---------------------------------------------------------------------------
# BATCH_SIZE=32
# FLUSH_EVERY=1500
# UPSERT_BATCH=500
# READAHEAD_BUFFER=100
# MAX_EMBED_CHARS=4096

# ---------------------------------------------------------------------------
# glibc memory tuning (cuts threaded-ONNX RSS bloat; leave as-is unless you
# know what you're doing)
# ---------------------------------------------------------------------------
# MALLOC_ARENA_MAX=2
# MALLOC_TRIM_THRESHOLD_=131072

# ---------------------------------------------------------------------------
# Qdrant storage (RAM vs search speed). Changing these re-creates collections,
# so they take effect on the next (re-)index of each project.
# ---------------------------------------------------------------------------
# VECTORS_ON_DISK=true       # memory-map dense vectors instead of RAM-resident
# SPARSE_ON_DISK=true        # store BM25 index on disk
# QUANTIZATION=true          # int8 dense vectors (~4x less RAM, rescored)
# MEMMAP_THRESHOLD_KB=20000  # segments above this size are memory-mapped

# ===========================================================================
# TUNING PRESETS — copy one block into your .env, uncommented, to switch
# machines without touching code or rebuilding the image.
# ===========================================================================

# --- 16C / 16GB (balanced, default) ---
# Nothing to set — the docker-compose.yml defaults already target this.

# --- 8C / 8GB (low memory) ---
# MCP_MEM_LIMIT=5g
# QDRANT_MEM_LIMIT=2g
# MCP_CPUS=7
# QDRANT_CPUS=2
# OMP_NUM_THREADS=6
# BATCH_SIZE=16
# FLUSH_EVERY=750
# VECTORS_ON_DISK=true
# QUANTIZATION=true

# --- 32C / 64GB (high throughput) ---
# MCP_MEM_LIMIT=40g
# QDRANT_MEM_LIMIT=20g
# MCP_CPUS=28
# QDRANT_CPUS=4
# OMP_NUM_THREADS=24
# BATCH_SIZE=64
# FLUSH_EVERY=4000
# VECTORS_ON_DISK=false   # keep vectors in RAM for fastest search
# QUANTIZATION=false      # plenty of RAM; skip quantization for max fidelity
